# Active provider for standard agents (Agents 1, 2, 3, 5)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Active provider for the Plan Writer (Agent 4)
# Set to 'anthropic' and update LLM_MODEL_WRITER when ready to upgrade
LLM_PROVIDER_WRITER=groq
LLM_MODEL_WRITER=llama-3.3-70b-versatile

# API keys — only the active provider's key is required
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# API security / web integration
# Set in production to require X-API-Key on generation, run, and artifact endpoints.
BUSINESS_PLAN_API_KEY=change_me
CORS_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=change_me

# Existing-auth adapter. In production, prefer auth middleware that sets
# request.state.authenticated_user_id. Enable this only behind a trusted proxy
# that strips inbound X-Authenticated-User-Id headers.
TRUST_AUTH_PROXY_HEADERS=false

# Stripe Checkout (server-side only; never prefix these with NEXT_PUBLIC_)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/?checkout=canceled
FUNDING_READY_PRICE_CENTS=49700
FUNDING_READY_CURRENCY=usd
# Explicit production safety switch; omit or keep false in test mode.
STRIPE_ALLOW_LIVE_MODE=false

# Database
DATABASE_URL=sqlite:///./output/business_plan_writer.db

# API execution and artifact delivery
ARTIFACT_ROOT=./output/runs
PIPELINE_TIMEOUT_SECONDS=900
DOWNLOAD_TOKEN_TTL_SECONDS=900
